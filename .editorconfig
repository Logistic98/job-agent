root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{java,py,js,vue,css,json,yml,yaml,xml}]
indent_style = space
indent_size = 4

[*.{js,vue,css,json,yml,yaml}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[Makefile]
indent_style = tab
